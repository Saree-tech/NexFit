@{
    Layout = "_Layout";
}

<style>
    body {
        background-color: #0b0f19 !important;
    }

    .security-card {
        background: #111625 !important;
        border: 1px solid rgba(245, 158, 11, 0.15) !important; /* Subtle amber border */
        border-radius: 16px !important;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5) !important;
    }

    .security-icon-container {
        background: rgba(245, 158, 11, 0.1) !important;
        color: #f59e0b !important;
        width: 60px;
        height: 60px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px auto;
        border: 1px solid rgba(245, 158, 11, 0.2);
    }

    .form-dark-input {
        background-color: #1a2035 !important;
        border: 1px solid rgba(255, 255, 255, 0.1) !important;
        color: #ffffff !important;
        border-radius: 8px !important;
        padding: 12px 14px;
        transition: all 0.2s ease;
    }

        .form-dark-input:focus {
            background-color: #1d243f !important;
            border-color: #f59e0b !important;
            box-shadow: 0 0 0 3px rgba(245, 158, 11, 0.15) !important;
            color: #ffffff !important;
        }

    .btn-warning-gradient {
        background: linear-gradient(135deg, #f59e0b, #d97706) !important;
        color: #0b0f19 !important;
        border: none !important;
        font-weight: 700;
        letter-spacing: 0.3px;
        padding: 12px;
        transition: all 0.2s ease;
    }

        .btn-warning-gradient:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 15px rgba(245, 158, 11, 0.3);
            background: linear-gradient(135deg, #fbbf24, #d97706) !important;
        }
</style>

<div class="container d-flex align-items-center justify-content-center" style="min-height: 75vh;">
    <div class="card security-card text-white w-100" style="max-width: 450px;">
        <div class="card-body p-4 p-sm-5">

            <div class="security-icon-container">
                <i class="bi bi-shield-lock-fill fs-3"></i>
            </div>

            <h3 class="fw-bold text-center text-white mb-2" style="letter-spacing: -0.5px;">Security Handshake</h3>
            <p class="text-muted text-center small mb-4 line-height-base">
                This is your first login session. For your profile privacy, please override the temporary system administrative pass token.
            </p>

            <form asp-action="ForceChangePassword" method="post">
                <div class="mb-4">
                    <label class="form-label text-secondary small fw-bold text-uppercase tracking-wider" style="letter-spacing: 0.5px;">Enter New Secure Password</label>
                    <input type="password" name="newPassword" class="form-control form-dark-input shadow-none" placeholder="••••••••" required minlength="6" />
                    <div class="form-text text-muted small mt-1">Choose a password with at least 6 characters.</div>
                </div>

                <button type="submit" class="btn btn-warning-gradient w-100 rounded-2 transition-all d-flex align-items-center justify-content-center gap-2">
                    <i class="bi bi-shield-check fs-5"></i> Update Password & Activate Profile
                </button>
            </form>

        </div>
    </div>
</div>