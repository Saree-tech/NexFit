    <ImplicitUsings>enable</ImplicitUsings>
    <UserSecretsId>163abf23-0323-40e8-a9fa-6fb299541e5c</UserSecretsId>
    <DockerDefaultTargetOS>Linux</DockerDefaultTargetOS>
